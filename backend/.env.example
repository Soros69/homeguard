# Copy this to .env and fill in real values
# NEVER commit .env to git

# Database (get from Supabase, Railway, or Neon — all have free tiers)
DATABASE_URL=postgresql://user:password@host:5432/homeguard

# JWT secret — generate with: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# Frontend origin (Vercel URL or localhost for dev)
ALLOWED_ORIGIN=http://localhost:3000

# Beta invite codes (comma-separated) — share these with friends & family
INVITE_CODES=FAMILY2024,BETA001,BETA002

NODE_ENV=development
PORT=4000
